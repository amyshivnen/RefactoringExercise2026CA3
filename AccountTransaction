package RefactoringExercise2026;

import java.time.LocalDateTime;

public class AccountTransaction {

    private LocalDateTime dateTime;
    private TransactionType transactionType;
    private double amount;

    public AccountTransaction() {
        this(LocalDateTime.now(), TransactionType.DEPOSIT, 0.0);
    }

    public AccountTransaction(LocalDateTime dateTime, TransactionType transactionType, double amount) {
        this.dateTime = (dateTime == null) ? LocalDateTime.now() : dateTime;
        this.transactionType = (transactionType == null) ? TransactionType.DEPOSIT : transactionType;

        if (amount < 0) throw new IllegalArgumentException("Amount cannot be negative.");
        this.amount = amount;
    }

    public LocalDateTime getDateTime() { return dateTime; }
    public TransactionType getTransactionType() { return transactionType; }
    public double getAmount() { return amount; }

    public void setDateTime(LocalDateTime dateTime) {
        this.dateTime = (dateTime == null) ? LocalDateTime.now() : dateTime;
    }

    public void setTransactionType(TransactionType transactionType) {
        this.transactionType = (transactionType == null) ? TransactionType.DEPOSIT : transactionType;
    }

    public void setAmount(double amount) {
        if (amount < 0) throw new IllegalArgumentException("Amount cannot be negative.");
        this.amount = amount;
    }

    @Override
    public String toString() {
        return "DateTime=" + dateTime + ", Type=" + transactionType + ", Amount=" + amount + "\n";
    }
}
